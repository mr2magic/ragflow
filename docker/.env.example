# =============================================================================
# RAGFlow Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# --- Docker image ---
RAGFLOW_IMAGE=infiniflow/ragflow:v0.24.0

# --- Document engine: elasticsearch | infinity | opensearch ---
DOC_ENGINE=elasticsearch
STACK_VERSION=8.11.3
COMPOSE_PROFILES=elasticsearch

# --- Ports (host) ---
SVR_HTTP_PORT=9380
SVR_WEB_HTTP_PORT=8080
SVR_WEB_HTTPS_PORT=8443
SVR_MCP_PORT=9382
ADMIN_SVR_HTTP_PORT=9381
EXPOSE_MYSQL_PORT=5455
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
REDIS_PORT=6379
ES_PORT=1200
KIBANA_PORT=6601
INFINITY_THRIFT_PORT=23817
INFINITY_HTTP_PORT=23820
INFINITY_PSQL_PORT=5432
OS_PORT=9201
TEI_PORT=6380

# --- Passwords (CHANGE THESE for non-local use) ---
MYSQL_PASSWORD=infini_rag_flow
ELASTIC_PASSWORD=infini_rag_flow
MINIO_PASSWORD=infini_rag_flow
REDIS_PASSWORD=infini_rag_flow
OPENSEARCH_PASSWORD=infini_rag_flow

# --- Service hostnames (internal Docker network) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DBNAME=rag_flow
MYSQL_MAX_PACKET=536870912
MINIO_HOST=minio
MINIO_USER=rag_flow
ES_HOST=es01
INFINITY_HOST=infinity
REDIS_HOST=redis
OS_HOST=opensearch01
TEI_HOST=tei

# --- OceanBase (optional) ---
OCEANBASE_HOST=oceanbase
OCEANBASE_PORT=2881
OCEANBASE_USER=root
OCEANBASE_PASSWORD=infini_rag_flow
OCEANBASE_DOC_DBNAME=ragflow_doc
OB_TENANT_NAME=ragflow
OB_TENANT_PASSWORD=infini_rag_flow
OB_SYS_PASSWORD=
OB_CLUSTER_NAME=ragflow
OB_MEMORY_LIMIT=6G
OB_SYSTEM_MEMORY=1G
OB_DATAFILE_SIZE=2G
OB_LOG_DISK_SIZE=4G

# --- SeekDB (optional) ---
SEEKDB_HOST=seekdb
SEEKDB_PORT=2881
SEEKDB_USER=root
SEEKDB_PASSWORD=infini_rag_flow
SEEKDB_DOC_DBNAME=ragflow_doc
SEEKDB_MEMORY_LIMIT=2G

# --- Hardware / runtime ---
DEVICE=cpu
MEM_LIMIT=8073741824
TZ=UTC
THREAD_POOL_MAX_WORKERS=128
DOC_BULK_SIZE=4
EMBEDDING_BATCH_SIZE=16
DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1
USE_DOCLING=0
REGISTER_ENABLED=1
DISABLE_PASSWORD_LOGIN=false

# --- TEI (Text Embeddings Inference, optional) ---
TEI_IMAGE_CPU=
TEI_IMAGE_GPU=
TEI_MODEL=

# =============================================================================
# API Keys — set your keys here, do not commit
# =============================================================================

BRAVE_SEARCH_API_KEY=
PERPLEXITY_API_KEY=
NEWSAPI_API_KEY=
JINA_API_KEY=
ANTHROPIC_API_KEY=
