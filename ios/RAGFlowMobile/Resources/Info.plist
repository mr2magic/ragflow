<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>RAGFlow</string>
    <key>CFBundleDisplayName</key>
    <string>RAGFlow</string>
    <key>CFBundleIdentifier</key>
    <string>com.dhorn.ragflowmobile</string>
    <key>CFBundleVersion</key>
    <string>8</string>
    <key>CFBundleShortVersionString</key>
    <string>0.8.0</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <!-- Required for BGProcessingTask (background document import & workflow runs) -->
    <key>UIBackgroundModes</key>
    <array>
        <string>processing</string>
    </array>
    <key>NSSupportsLiveActivities</key>
    <true/>
    <key>NSSupportsLiveActivitiesFrequentUpdates</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>RAGFlow uses the camera to scan physical documents and import them into your knowledge base.</string>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <true/>
        <key>UISceneConfigurations</key>
        <dict/>
    </dict>
    <key>UIFileSharingEnabled</key>
    <true/>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
        <!-- Ollama runs on the local network; iCloud Private Relay cannot route
             to private hostnames such as the-black-pearl:11434 -->
        <key>NSAllowsLocalNetworking</key>
        <true/>
    </dict>
    <key>NSLocalNetworkUsageDescription</key>
    <string>RAGFlow connects to Ollama on your local network to run AI models privately on your own hardware.</string>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Deep-link URL scheme for Widget and Share Extension → ragflow://kb/{id} -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>ragflow</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.dhorn.ragflowmobile</string>
        </dict>
    </array>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.dhorn.ragflowmobile.import</string>
        <string>com.dhorn.ragflowmobile.workflow</string>
    </array>
</dict>
</plist>
